datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   // The recipient
  type      String   // MATCH_FOUND, SESSION_INVITE, etc.
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
