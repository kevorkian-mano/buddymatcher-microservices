datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Profile {
  id          String       @id @default(uuid())
  userId      String       @unique   // FK to user-service
  courses     Course[]
  topics      Topic[]
  studyGoals  StudyGoal[]
  preferences Preferences?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model StudyGoal {
  id        String  @id @default(uuid())
  goal      String
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Course {
  id        String  @id @default(uuid())
  name      String
  code      String?
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Topic {
  id        String  @id @default(uuid())
  name      String
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Preferences {
  id            String  @id @default(uuid())
  profileId     String  @unique
  profile       Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  studyPace     String? // slow | moderate | fast
  studyMode     String? // online | in-person | both
  groupSize     String? // solo | small | large
  studyStyle    String? // notes | listening | discussion | quiet | other
}
